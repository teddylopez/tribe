ions\";\n\nfunction HomePage() {\n  const dispatch = useDispatch();\n  const productList = useSelector((state) => state.productList);\n  const { loading, error, products } = productList;\n\n  useEffect(() => {\n    dispatch(listProducts({}));\n  }, [dispatch]);\n\n  return (\n    <div>\n      <Banner />\n      {loading ? (\n        <LoadingBox></LoadingBox>\n      ) : error ? (\n        <MessageBox variant=\"danger\">{error}</MessageBox>\n      ) : (\n        <div className=\"row center\">\n          {products.map((product) => (\n            <Product key={product._id} product={product}></Product>\n          ))}\n        </div>\n      )}\n      <HomePageSection />\n      {loading ? (\n        <LoadingBox></LoadingBox>\n      ) : error ? (\n        <MessageBox variant=\"danger\">{error}</MessageBox>\n      ) : (\n        <div className=\"row center\">\n          {products.map((product) => (\n            <Product key={product._id} product={product}></Product>\n          ))}\n        </div>\n      )}\n      <HomePageSection />\n    </div>\n  );\n}\n\nexport default HomePage;\n","/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/components/HomePage/Banner.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/actions/cartActions.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/Product.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/SellerPage.js",["123","124"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/ProductPage.js",[],{"ruleId":"125","replacedBy":"126"},{"ruleId":"127","replacedBy":"128"},{"ruleId":"125","replacedBy":"129"},{"ruleId":"127","replacedBy":"130"},{"ruleId":"125","replacedBy":"131"},{"ruleId":"127","replacedBy":"132"},{"ruleId":"133","severity":1,"message":"134","line":100,"column":13,"nodeType":"135","messageId":"136","endLine":100,"endColumn":17},{"ruleId":"137","severity":1,"message":"138","line":47,"column":6,"nodeType":"139","endLine":47,"endCo