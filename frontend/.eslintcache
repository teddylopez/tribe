assName=\"row center\">\n          {products.map((product) => (\n            <Product key={product._id} product={product}></Product>\n          ))}\n        </div>\n      )}\n      <HomePageSection />\n    </div>\n  );\n}\n\nexport default HomePage;\n","/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/components/HomePage/Banner.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/actions/cartActions.js",[],{"ruleId":"111","replacedBy":"112"},{"ruleId":"113","replacedBy":"114"},{"ruleId":"111","replacedBy":"115"},{"ruleId":"113","replacedBy":"116"},{"ruleId":"111","replacedBy":"117"},{"ruleId":"113","replacedBy":"118"},{"ruleId":"119","severity":1,"message":"120","line":100,"column":13,"nodeType":"121","messageId":"122","endLine":100,"endColumn":17},{"ruleId":"123","severity":1,"message":"124","line":47,"column":6,"nodeType":"125","endLine":47,"endColumn":77,"suggestions":"126"},{"ruleId":"119","severity":1,"message":"127","line":2,"column":8,"nodeType":"121","messageId":"122","endLine":2,"endColumn":12},"no-native-reassign",["128"],"no-negated-in-lhs",["129"],["128"],["129"],["128"],["129"],"no-unused-vars","'data' is assigned a value but never used.","Identifier","unusedVar","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'sellerMode' and 'userInfo._id'. Either include them or remove the dependency array.","ArrayExpression",["130"],"'data' is defined but never used.","no-global-assign","no-unsafe-negation",{"desc":"131","fix":"132"},"Update the dependencies array to be: [createdProduct, dispatch, props.history, sellerMode, successCreate, successDelete, userInfo._id]",{"range":"133","text":"134"},[1451,1522],"[createdProduct, dispatch, props.history, sellerMode, successCreate, successDelete, userInfo._id]"]