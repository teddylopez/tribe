,"messages":"147","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"148","messages":"149","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"150","messages":"151","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/reportWebVitals.js",[],["152","153"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/reducers/cartReducers.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/CartPage.js",[],["154","155"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/LoadingBox.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/constants/productConstants.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/constants/cartConstants.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/actions/cartActions.js",[],["156","157"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/ProductPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/HomePage.js",["158"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/store.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/reducers/productReducers.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/App.js",["159"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/SigninPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/reducers/userReducers.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/Product.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/components/HomePage/HomePageSection.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/components/HomePage/Banner.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/actions/userActions.js",["160"],"import Axios from \"axios\";\nimport {\n  USER_DETAILS_FAIL,\n  USER_DETAILS_REQUEST,\n  USER_DETAILS_SUCCESS,\n  USER_REGISTER_FAIL,\n  USER_REGISTER_REQUEST,\n  USER_REGISTER_SUCCESS,\n  USER_SIGNIN_FAIL,\n  USER_SIGNIN_REQUEST,\n  USER_SIGNIN_SUCCESS,\n  USER_SIGNOUT,\n  USER_UPDATE_PROFILE_REQUEST,\n  USER_UPDATE_PROFILE_SUCCESS,\n  USER_UPDATE_PROFILE_RESET,\n  USER_UPDATE_PROFILE_FAIL,\n} from \"../constants/userConstants\";\n\nexport const signin = (email, password) => async (dispatch) => {\n  dispatch({ type: USER_SIGNIN_REQUEST, payload: { email, password } });\n  try {\n    const { data } = await Axios.post(\"/api/users/signin\", { email, password });\n    dispatch({ type: USER_SIGNIN_SUCCESS, payload: data });\n    localStorage.setItem(\"userInfo\", JSON.stringify(data));\n  } catch (error) {\n    dispatch({\n      type: USER_SIGNIN_FAIL,\n      payload:\n        error.response && error.response.data.message\n          ? error.response.data.message\n          : error.message,\n    });\n  }\n};\n\nexport const register = (name, email, password) => async (dispatch) => {\n  dispatch({ type: USER_REGISTER_REQUEST, payload: { email, password } });\n  try {\n    const { data } = await Axios.post(\"/api/users/register\", {\n      name,\n      email,\n      password,\n    });\n    dispatch({ type: USER_REGISTER_SUCCESS, payload: data });\n    dispatch({ type: USER_SIGNIN_SUCCESS, payload: data });\n    localStorage.setItem(\"userInfo\", JSON.stringify(data));\n  } catch (error) {\n    dispatch({\n      type: USER_REGISTER_FAIL,\n      payload:\n        error.response && error.response.data.message\n          ? error.response.data.message\n          : error.message,\n    });\n  }\n};\n\nexport const signout = () => (dispatch) => {\n  localStorage.removeItem(\"userInfo\");\n  localStorage.removeItem(\"cartItems\");\n  localStorage.removeItem(\"shippingAddress\");\n  dispatch({ type: USER_SIGNOUT });\n};\n\nexport const userDetails = (userId) => async (dispatch, getState) => {\n  dispatch({ type: USER_DETAILS_REQUEST, payload: userId });\n  const {\n    userSignin: { userInfo },\n  } = getState();\n  try {\n    const { data } = await Axios.get(`/api/users/${userId}`, {\n      headers: { Authorization: `Bearer ${userInfo.token}` },\n    });\n    dispatch({ type: USER_DETAILS_SUCCESS, payload: data });\n  } catch (error) {\n    const message =\n      error.response && error.response.data.message\n        ? error.response.data.message\n        : error.message;\n    dispatch({ type: USER_DETAILS_FAIL, payload: message });\n  }\n};\n\nexport const updateUserProfile = (user) => async (dispatch, getState) => {\n  dispatch({ type: USER_UPDATE_PROFILE_REQUEST, payload: user });\n  const {\n    userSignin: { userInfo },\n  } = getState();\n  try {\n    const { data } = await Axios.put(`/api/users/profile`, user, {\n      headers: { Authorization: `Bearer ${userInfo.token}` },\n    });\n    dispatch({ type: USER_UPDATE_PROFILE_SUCCESS, payload: data });\n    dispatch({ type: USER_SIGNIN_SUCCESS, payload: data });\n    localStorage.setItem(\"userInfo\", JSON.stringify(data));\n  } catch (error) {\n    const message =\n      error.response && error.response.data.message\n        ? error.response.data.message\n        : error.message;\n    dispatch({ type: USER_UPDATE_PROFILE_FAIL, payload: message });\n  }\n};\n","/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/RegisterPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/constants/userConstants.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/ShippingPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/PaymentPage.js",["161"],"import React, { useState } from \"react\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport CheckoutSteps from \"../components/CheckoutSteps\";\nimport { savePaymentMethod } from \"../actions/cartActions\";\n\nfunction PaymentPage(props) {\n  const cart = useSelector((state) => state.cart);\n  const { shippingAddress } = cart;\n  if (!shippingAddress.address) {\n    props.history.push(\"/shipping\");\n  }\n\n  const [paymentMethod, setPaymentMethod] = useState(\"PayPal\");\n  const dispatch = useDispatch();\n\n  const submitHandler = (e) => {\n    e.preventDefault();\n    dispatch(savePaymentMethod(paymentMethod));\n    props.history.push(\"/placeorder\");\n  };\n\n  return (\n    <div>\n      <CheckoutSteps step1 step2 step3></CheckoutSteps>\n      <form className=\"form\" onSubmit={submitHandler}>\n        <div>\n          <h1>Payment Method</h1>\n        </div>\n        <div>\n          <div>\n            <input\n              type=\"radio\"\n              id=\"paypal\"\n              value=\"PayPal\"\n              name=\"paymentMethod\"\n              required\n              defaultChecked\n              // onChange={(e) => setPaymentMethod(e.target.value)}\n            ></input>\n            <label htmlFor=\"paypal\">PayPal</label>\n          </div>\n        </div>\n        <div>\n          <div>\n            <input\n              type=\"radio\"\n              id=\"stripe\"\n              value=\"Stripe\"\n              name=\"paymentMethod\"\n              required\n              // onChange={(e) => setPaymentMethod(e.target.value)}\n            ></input>\n            <label htmlFor=\"stripe\">Stripe</label>\n          </div>\n        </div>\n        <div>\n          <label />\n          <button className=\"primary\" type=\"submit\">\n            Continue\n          </button>\n        </div>\n      </form>\n    </div>\n  );\n}\n\nexport default PaymentPage;\n","/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/OrderPage.js",[],["162","163"],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/constants/orderConstants.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/reducers/orderReducers.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/actions/orderActions.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/ConfirmationPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/Rating.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/index.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/OrderHistoryPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/UserProfilePage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/PrivateRoute.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/AdminRoute.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/pages/ProductListPage.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/actions/productActions.js",[],"/Users/tedlopez/Documents/projects/react/tribe/frontend/src/components/CheckoutSteps.js",[],{"ruleId":"164","replacedBy":"165"},{"ruleId":"166","replacedBy":"167"},{"ruleId":"164","replacedBy":"168"},{"ruleId":"166","replacedBy":"169"},{"ruleId":"164","replacedBy":"170"},{"ruleId":"166","replacedBy":"171"},{"ruleId":"172","severity":1,"message":"173","line":2,"column":8,"nodeType":"174","messageId":"175","endLine":2,"endColumn":12},{"ruleId":null,"fatal":true,"severity":2,"message":"176","line":96,"column":68},{"ruleId":"172","severity":1,"message":"177","line":15,"column":3,"nodeType":"174","messageId":"175","endLine":15,"endColumn":28},{"ruleId":"172","severity":1,"message":"178","line":13,"column":25,"nodeType":"174","messageId":"175","endLine":13,"endColumn":41},{"ruleId":"164","replacedBy":"179"},{"ruleId":"166","replacedBy":"180"},"no-native-reassign",["181"],"no-negated-in-lhs",["182"],["181"],["182"],["181"],["182"],"no-unused-vars","'data' is defined but never used.","Identifier","unusedVar","Parsing error: JSX value should be either an expression or a quoted JSX text\n\n  94 |         <main>\n  95 |           <Route path=\"/cart/:id?\" component={CartPage}></Route>\n> 96 |           <Route path=\"/product/:id\" component={ProductPage} exact=true />\n     |                                                                    ^\n  97 |           <Route path=\"/signin\" component={SigninPage}></Route>\n  98 |           <Route path=\"/register\" component={RegisterPage}></Route>\n  99 |           <Route path=\"/shipping\" component={ShippingPage}></Route>","'USER_UPDATE_PROFILE_RESET' is defined but never used.","'setPaymentMethod' is assigned a value but never used.",["181"],["182"],"no-global-assign","no-unsafe-negation"]